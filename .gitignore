.venv/
__pycache__/
*.pyc
.pytest_cache/
data/sessions.json

# Recorded training sets — user-generated, not source
data/set_*/

# OMC / agent harness state (per-machine, volatile)
.omc/

# Large model weights — distribute out-of-band (documented in README)
pose_landmarker_heavy.task
pose_landmarker_full.task
pose_landmarker_lite.task
yolov8n-pose.pt
*.pt
*.task

# YOLO fine-tuning data (phase 7.4 + phase 9 A/B) — videos / extracted
# frames / training runs are huge, user-supplied, and often subject to
# athlete-likeness rights. Keep configs (.yaml) in-repo, everything
# else stays local.
data/raw_videos/
data/training/images/
data/training/labels/
data/training/train.txt
data/training/val.txt
# Phase 9.x — phase_a/, phase_b/ subdirs follow the same shape; only
# the swimmer_det.yaml / pose.yaml configs go in repo.
data/training/phase_*/frames/
data/training/phase_*/labels/
data/training/phase_*/labels_raw/
data/training/phase_*/train.txt
data/training/phase_*/val.txt
runs/

# macOS Finder metadata
.DS_Store

# Claude Code worktree registry (per-machine, never share)
.claude/

# Office temp lock files (~$foo.pptx when PowerPoint is open)
~$*

# Local lesson materials / course PPT — out-of-scope for this repo
docs/lessons/
